model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  phone        String?
  address      String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Provider side: gear owned by this user (when role = PROVIDER)
  gearItems GearItem[] @relation("ProviderGear")

  // Customer side
  rentalOrders RentalOrder[] @relation("CustomerRentals")
  reviews      Review[]      @relation("CustomerReviews")

  @@map("users")
}
